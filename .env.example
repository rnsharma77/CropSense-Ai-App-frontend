# CropSense Frontend Environment Variables
# Copy this file to .env.local and fill in actual values for your environment
# NEVER commit .env files with secrets to version control

# ===== API CONFIGURATION =====
# Backend API base URL
# For local development: /api (proxied via vite.config.ts to http://localhost:8080/api)
# For Vercel production with rewrites: /api
# For direct backend hosting: use the full backend URL
VITE_API_BASE_URL=http://localhost:8080/api

# ===== DEPLOYMENT ENVIRONMENT =====
# Set to 'production' for production builds, 'development' for dev
VITE_ENV=development

# ===== DEBUG & LOGGING =====
# Enable debug logging to console
VITE_DEBUG=false

# ===== OPTIONAL INTEGRATIONS =====
# Analytics and monitoring
VITE_ANALYTICS_URL=
VITE_SENTRY_DSN=
